// Prisma schema for Better Auth + Portfolio CMS
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Better Auth Models ───

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user") // Added role for RBAC
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[] // Tracks actions performed by this admin

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ─── Portfolio CMS Models ───

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("text") // text, html, markdown, json
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("site_config")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  lede        String
  label       String   // e.g. "screenshot — dashboard"
  meta        String   // e.g. "2025 · Government"
  desc        String
  year        String
  status      String   @default("In production")
  role        String   @default("Full-stack")
  stack       String   // JSON array
  category    String   @default("General")
  tags        String   // JSON array
  image       String?  // uploadthing public URL
  liveUrl     String?  // public demo / deployed URL
  githubUrl   String?  // source repo URL
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections    ProjectSection[]

  @@map("project")
}

model ProjectSection {
  id        String   @id @default(cuid())
  projectId String
  order     Int      @default(0)
  heading   String
  content   String // HTML content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_section")
}

model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  lede      String
  date      String   // e.g. "2026 · 04 · 22"
  readTime  String   @default("5 min read")
  category  String   @default("Notes")
  tags      String   // JSON array
  content   String // HTML content
  image     String?  // uploadthing public URL (cover image)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("article")
}

model ChatSuggestion {
  id        String   @id @default(cuid())
  question  String
  kind      String   @default("ask") // ask, tool
  tool      String?  // message, meeting
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_suggestion")
}

model ChatResponse {
  id        String   @id @default(cuid())
  trigger   String   // keyword or phrase to match
  response  String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_response")
}

model ChatConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  pageTitle   String   @default("Ask Ali anything")
  modelName   String   @default("claude-3-5-sonnet")
  systemPrompt String  @default("")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("chat_config")
}

// ─── Security Models ───

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String   // e.g. "update_article", "delete_user"
  entityType  String   // e.g. "article", "project"
  entityId    String
  metadata    String? // JSON string for changes/context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([action])
  @@map("audit_log")
}
