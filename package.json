{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "next build",
    "build:strict": "pnpm typecheck && pnpm lint && pnpm test:production && pnpm build",
    "check": "pnpm typecheck && pnpm lint && pnpm test:production",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-admin": "tsx prisma/seed-admin.ts",
    "db:make-admin": "tsx prisma/make-admin.ts",
    "db:studio": "prisma studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "preview": "next build && next start",
    "start": "next start",
    "test": "node --test tests/production-contract.test.mjs",
    "test:production": "node --test tests/production-contract.test.mjs",
    "typecheck": "tsc --noEmit"
  },
